---
// src/layouts/Layout.astro
import ChatWidget from '../components/ChatWidget.jsx';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gilberto Romero-Cano | Portfolio</title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="Portfolio of Gilberto Romero-Cano, a Computer Science student at CU Denver building full-stack applications, ML telemetry platforms, and hardware-integrated robotics." />
    <meta name="author" content="Gilberto Romero-Cano" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0c0d12] text-slate-300 font-sans antialiased selection:bg-blue-500/20 flex flex-col min-h-screen relative overflow-x-hidden">
    
    <!-- Sticky Technical Drawing Title Block Nav -->
    <nav class="border-b border-slate-850 bg-slate-950 sticky top-0 z-50 select-none">
      <div class="max-w-4xl mx-auto grid grid-cols-3 sm:grid-cols-6 border-x border-slate-850 text-[11px] font-mono items-stretch">
        <!-- Logo / Designer Identifier -->
        <div class="col-span-2 border-r border-slate-850 p-4 flex items-center">
          <a href="/Portfolio/" class="text-white font-display font-extrabold text-sm tracking-wider hover:text-blue-400 transition flex items-center gap-2">
            GRC // PORTFOLIO <span class="w-1.5 h-1.5 bg-blue-500 rounded-none inline-block"></span>
          </a>
        </div>
        
        <!-- Metadata Block 1 (Desktop) -->
        <div class="hidden sm:flex flex-col justify-center border-r border-slate-850 px-4 py-2 text-slate-500 uppercase">
          <span class="text-[8px] text-slate-600 font-bold block leading-none">DESIGNER</span>
          <span class="text-slate-300 font-semibold mt-0.5">G. ROMERO-CANO</span>
        </div>

        <!-- Metadata Block 2 (Desktop) -->
        <div class="hidden sm:flex flex-col justify-center border-r border-slate-850 px-4 py-2 text-slate-500 uppercase">
          <span class="text-[8px] text-slate-600 font-bold block leading-none">SYS_STATUS</span>
          <span class="text-emerald-500 font-bold mt-0.5 flex items-center gap-1">
            <span class="w-1 h-1 bg-emerald-500"></span> ACTIVE // OK
          </span>
        </div>

        <!-- Navigation Links -->
        <div class="col-span-1 sm:col-span-2 flex items-stretch divide-x divide-slate-850 border-l border-slate-850 sm:border-l-0">
          <a href="/Portfolio/#projects" class="flex-1 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-900 transition font-bold py-2">
            PROJECTS
          </a>
          <a href="/Portfolio/about" class="flex-1 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-900 transition font-bold py-2">
            ABOUT
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content Area -->
    <div class="flex-grow">
      <slot /> 
    </div>

    <!-- Technical Footer -->
    <footer class="border-t border-slate-850 bg-slate-950/60 py-8 mt-24">
      <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-mono text-slate-500">
        <div class="flex items-center gap-2">
          <span>&copy; {new Date().getFullYear()} GILBERTO ROMERO-CANO</span>
          <span class="text-slate-700">|</span>
          <span class="text-[10px] text-slate-600">DWG. REF: GRC-2026-PORTFOLIO</span>
        </div>
        <div class="flex gap-4">
          <a href="https://github.com/GIlbertoRCP" target="_blank" rel="noopener noreferrer" class="hover:text-white transition uppercase">GITHUB</a>
          <span class="text-slate-750">•</span>
          <a href="/Portfolio/about" class="hover:text-white transition uppercase">ABOUT</a>
        </div>
      </div>
    </footer>

    <!-- Client-Side Assistant Chat -->
    <ChatWidget client:load /> 

  </body>
</html>

<style is:global>
  /* Custom scrollbar and base style updates */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #09090b; /* zinc-950 */
  }
  ::-webkit-scrollbar-thumb {
    background: #27272a; /* zinc-800 */
    border-radius: 0px; /* Sharp technical edge */
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #3f3f46; /* zinc-700 */
  }
</style>