---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-4xl mx-auto px-6 py-12 md:py-20 space-y-24">

    <!-- Hero Section -->
    <section class="space-y-8 relative">
      
      <div class="space-y-4">
        <h1 class="text-4xl sm:text-6xl font-display font-extrabold tracking-tight text-white leading-none">
          GILBERTO ROMERO-CANO
        </h1>
        <p class="text-sm font-mono text-slate-500 uppercase tracking-widest leading-none pt-1">
          // SOFTWARE ARCHITECT // MACHINE LEARNING // EMBEDDED TELEMETRY
        </p>
      </div>
      
      <p class="text-sm sm:text-base text-slate-400 leading-relaxed max-w-3xl font-sans">
        Computer Science student at <strong class="text-slate-200">CU Denver</strong> with a strong foundation in software architecture, backend development, and machine learning. Experienced in building end-to-end applications, from data modeling in Python to engineering scalable backends in C# and FastAPI.
      </p>

      <!-- Contact Info Row -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-500 font-mono border-t border-b border-slate-850 py-3">
        <div class="flex items-center gap-1.5"><span class="text-slate-700">LOC:</span> Denver, CO</div>
        <div class="flex items-center gap-1.5"><span class="text-slate-700">TEL:</span> <a href="tel:7206936526" class="hover:text-blue-400 transition">(720) 693-6526</a></div>
        <div class="flex items-center gap-1.5"><span class="text-slate-700">MAIL:</span> <a href="mailto:gilbertorcp712@gmail.com" class="hover:text-blue-400 transition">gilbertorcp712@gmail.com</a></div>
        <div class="flex items-center gap-1.5"><span class="text-slate-700">LINK:</span> <a href="https://linkedin.com/in/gromerocano/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition">linkedin.com/in/gromerocano/</a></div>
      </div>

      <!-- Key Metrics Badge Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 border border-slate-850 bg-slate-950 font-mono divide-x divide-y sm:divide-y-0 divide-slate-850 max-w-3xl select-none">
        <div class="p-4 flex flex-col justify-between">
          <span class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">[01] EDUCATION</span>
          <span class="text-slate-200 text-xs font-semibold mt-2">CU DENVER CS</span>
        </div>
        <div class="p-4 flex flex-col justify-between">
          <span class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">[02] SPECIALTY</span>
          <span class="text-slate-200 text-xs font-semibold mt-2">ML &amp; SYSTEMS</span>
        </div>
        <div class="p-4 flex flex-col justify-between">
          <span class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">[03] PORTFOLIO</span>
          <span class="text-slate-200 text-xs font-semibold mt-2">5 MAJOR SYSTEMS</span>
        </div>
        <div class="p-4 flex flex-col justify-between">
          <span class="text-[9px] text-slate-500 uppercase font-bold tracking-wider">[04] LIVE_DEMOS</span>
          <span class="text-slate-200 text-xs font-semibold mt-2">PLAYABLE SIMS</span>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 pt-2 font-mono">
        <a href="#projects" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold border border-blue-500 hover:border-blue-600 shadow-flat-slate hover:translate-y-[-1px] transition-all text-xs uppercase tracking-wider">
          EXPLORE PROJECTS &rarr;
        </a>
        <a href="/Portfolio/about" class="px-5 py-2.5 bg-[#0f1115] hover:bg-slate-900 border border-slate-855 border-slate-850 text-slate-300 hover:text-white shadow-flat-slate hover:translate-y-[-1px] transition-all text-xs uppercase tracking-wider">
          ABOUT ME // PROFILE
        </a>
      </div>
    </section>

    <!-- Primary Featured Projects Section -->
    <section id="projects" class="pt-12 space-y-8 scroll-mt-20">
      
      <!-- Section Header -->
      <div class="border-b border-slate-850 pb-4 font-mono">
        <div class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1">// SEC_01 // CORE_SYSTEMS_INDEX</div>
        <h2 class="text-2xl font-display font-extrabold text-white uppercase tracking-tight">Featured ML &amp; Telemetry Systems</h2>
        <p class="text-xs text-slate-400 mt-1">Deep, end-to-end applications demonstrating machine learning models and distributed infrastructure.</p>
      </div>
      
      <!-- Primary Grid -->
      <div class="grid md:grid-cols-3 gap-6">
        
        <!-- Project 1: Predictive SDN -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-blue-400 font-bold uppercase tracking-wider">SYS_REF: CSCI-4930-HL1</span>
              <span class="text-slate-500 uppercase">[SYS.ACTIVE]</span>
            </div>
            <h3 class="text-lg font-display font-extrabold text-white mb-3 group-hover:text-blue-400 transition tracking-tight">Predictive Network Telemetry System</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              Traffic engineering pipeline using PyTorch LSTM forecasts, Stable-Baselines3 DQN agents, and Apache Kafka to reroute traffic dynamically.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">KAFKA</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">LSTM / DQN</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">MININET</span>
            </div>
            <a href="/Portfolio/projects/predictive-sdn" class="text-blue-400 font-bold text-xs hover:text-blue-300 transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

        <!-- Project 2: F1 Oracle -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-purple-400 font-bold uppercase tracking-wider">SYS_REF: ML-RANKER-01</span>
              <span class="text-slate-500 uppercase">[SYS.STABLE]</span>
            </div>
            <h3 class="text-lg font-display font-extrabold text-white mb-3 group-hover:text-purple-400 transition tracking-tight">F1 Oracle Prediction Platform</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              Machine Learning race predictions utilizing XGBRanker pairwise ranking on FastF1 timing telemetry, paired with Monte Carlo simulators.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">FASTF1</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">XGBOOST</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">FASTAPI</span>
            </div>
            <a href="/Portfolio/projects/f1-oracle" class="text-purple-400 font-bold text-xs hover:text-purple-300 transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

        <!-- Project 3: Humanoid Locomotion -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-emerald-400 font-bold uppercase tracking-wider">SYS_REF: RL-PPO-3D</span>
              <span class="text-slate-500 uppercase">[SYS.ACTIVE]</span>
            </div>
            <h3 class="text-lg font-display font-extrabold text-white mb-3 group-hover:text-emerald-400 transition tracking-tight">Humanoid Locomotion</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              3D bipedal bionic humanoid agent trained using Proximal Policy Optimization (PPO) in MuJoCo physics engine across 160 million simulation steps.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">MUJOCO</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">PPO (RL)</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">5-PT LIDAR</span>
            </div>
            <a href="/Portfolio/projects/motor-control-locomotion" class="text-emerald-400 font-bold text-xs hover:text-emerald-300 transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

      </div>
    </section>

    <!-- Secondary Systems & Coursework Section -->
    <section class="space-y-8">
      
      <!-- Section Header -->
      <div class="border-b border-slate-850 pb-4 font-mono">
        <div class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1">// SEC_02 // SYSTEM_BUILD_INDEX</div>
        <h2 class="text-2xl font-display font-extrabold text-white uppercase tracking-tight">Other Engineering Projects</h2>
        <p class="text-xs text-slate-400 mt-1">Robotics, mobile development, and object-oriented systems architectures.</p>
      </div>

      <!-- Secondary Grid -->
      <div class="grid md:grid-cols-3 gap-6">
        
        <!-- Project 3: Bomb Squad Robot -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-slate-500 font-bold uppercase tracking-wider">REF: EMBEDDED-NODE-3</span>
              <span class="text-slate-500 uppercase">[DEVCYCLE]</span>
            </div>
            <h3 class="text-lg font-display font-bold text-white mb-3 group-hover:text-blue-400 transition tracking-tight">Wireless EOD Disposal Rover</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              A distributed 3-node wireless system running ESP-NOW to steer a 4-DOF Mecanum rover, incorporating claw shaking sensor parameters.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">ESP32</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">ESP-NOW</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">C++</span>
            </div>
            <a href="/Portfolio/projects/bomb-squad-robot" class="text-slate-400 font-bold text-xs hover:text-white transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

        <!-- Project 4: Tap-Tap Trivia -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-slate-500 font-bold uppercase tracking-wider">REF: MOBILE-APP-BUZZ</span>
              <span class="text-slate-500 uppercase">[DEVCYCLE]</span>
            </div>
            <h3 class="text-lg font-display font-bold text-white mb-3 group-hover:text-blue-400 transition tracking-tight">Tap-Tap Trivia (Group App)</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              A responsive React Native front-end buzzer mobile app developed using Git and Agile workflows to coordinate team merges.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">REACT NATIVE</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">AGILE / GIT</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">MOBILE</span>
            </div>
            <a href="/Portfolio/projects/tap-tap-trivia" class="text-slate-400 font-bold text-xs hover:text-white transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

        <!-- Project 5: E-Commerce Cart Simulation -->
        <article class="bg-[#0f1115] border border-slate-850 p-6 flex flex-col justify-between transition-all duration-200 hover:border-slate-700 hover:translate-y-[-2px] shadow-flat-slate group relative overflow-hidden">
          <div>
            <div class="flex justify-between items-center mb-4 font-mono text-[9px]">
              <span class="text-slate-500 font-bold uppercase tracking-wider">REF: NET-OOP-SIM</span>
              <span class="text-slate-500 uppercase">[DEVCYCLE]</span>
            </div>
            <h3 class="text-lg font-display font-bold text-white mb-3 group-hover:text-blue-400 transition tracking-tight">E-Commerce Cart Simulation</h3>
            <p class="text-slate-400 mb-6 text-xs leading-relaxed">
              Modular catalog system using OOP inheritance and polymorphism to integrate digital, physical, and subscription products with Generic Collections.
            </p>
          </div>
          <div>
            <div class="flex flex-wrap gap-1.5 mb-6 font-mono text-[9px]">
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">C#</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">.NET CORE</span>
              <span class="px-2 py-0.5 bg-slate-900 border border-slate-850 text-slate-400">OOP</span>
            </div>
            <a href="/Portfolio/projects/ecommerce-cart" class="text-slate-400 font-bold text-xs hover:text-white transition mt-auto inline-flex items-center gap-1 font-mono">
              [VIEW DETAILS] &rarr;
            </a>
          </div>
        </article>

      </div>
    </section>

    <!-- Skills Matrix Section -->
    <section class="space-y-8 select-none">
      
      <!-- Section Header -->
      <div class="border-b border-slate-850 pb-4 font-mono">
        <div class="text-[10px] text-slate-500 uppercase tracking-widest font-bold mb-1">// SEC_03 // CORE_SPECIFICATION_MATRIX</div>
        <h2 class="text-2xl font-display font-extrabold text-white uppercase tracking-tight">Technical Core Matrix</h2>
        <p class="text-xs text-slate-400 mt-1">Structured view of my engineering languages, runtimes, and hardware tooling.</p>
      </div>

      <!-- Specs Grid (Spreadsheet-like tabular design) -->
      <div class="grid sm:grid-cols-2 md:grid-cols-4 border border-slate-850 divide-y sm:divide-y-0 divide-x divide-slate-850 bg-slate-950 font-mono text-[11px]">
        
        <!-- Column 1 -->
        <div class="flex flex-col">
          <div class="bg-slate-900 border-b border-slate-850 p-3 text-white font-bold uppercase tracking-wider">
            [01] LANGUAGES
          </div>
          <div class="divide-y divide-slate-900 flex-grow">
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>C#</span> <span class="text-slate-600 text-[10px]">OOP / .NET</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>C++</span> <span class="text-slate-600 text-[10px]">EMBEDDED</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>C</span> <span class="text-slate-600 text-[10px]">SYSTEMS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>PYTHON</span> <span class="text-slate-600 text-[10px]">ML &amp; DATA</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>JAVASCRIPT</span> <span class="text-slate-600 text-[10px]">WEB APPS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>SQL</span> <span class="text-slate-600 text-[10px]">DATABASES</span>
            </div>
          </div>
        </div>

        <!-- Column 2 -->
        <div class="flex flex-col">
          <div class="bg-slate-900 border-b border-slate-850 p-3 text-white font-bold uppercase tracking-wider">
            [02] FRAMEWORKS / LIBS
          </div>
          <div class="divide-y divide-slate-900 flex-grow">
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>FASTAPI</span> <span class="text-slate-600 text-[10px]">API ENGINE</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>PANDAS / NUMPY</span> <span class="text-slate-600 text-[10px]">DATA PREP</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>SCIKIT-LEARN</span> <span class="text-slate-600 text-[10px]">MODELS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>REACT NATIVE</span> <span class="text-slate-600 text-[10px]">MOBILE UI</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>TAILWIND CSS</span> <span class="text-slate-600 text-[10px]">STYLING</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>VERCEL</span> <span class="text-slate-600 text-[10px]">HOSTING</span>
            </div>
          </div>
        </div>

        <!-- Column 3 -->
        <div class="flex flex-col">
          <div class="bg-slate-900 border-b border-slate-850 p-3 text-white font-bold uppercase tracking-wider">
            [03] DEV TOOLING
          </div>
          <div class="divide-y divide-slate-900 flex-grow">
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>GIT / GITHUB</span> <span class="text-slate-600 text-[10px]">VCS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>DOCKER</span> <span class="text-slate-600 text-[10px]">CONTAINERS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>POSTMAN</span> <span class="text-slate-600 text-[10px]">API TEST</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>LINUX BASH</span> <span class="text-slate-600 text-[10px]">SHELL</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>VS CODE / EMACS</span> <span class="text-slate-600 text-[10px]">EDITORS</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>MININET</span> <span class="text-slate-600 text-[10px]">NET WORK</span>
            </div>
          </div>
        </div>

        <!-- Column 4 -->
        <div class="flex flex-col">
          <div class="bg-slate-900 border-b border-slate-850 p-3 text-white font-bold uppercase tracking-wider">
            [04] SPECIALTIES
          </div>
          <div class="divide-y divide-slate-900 flex-grow">
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>ESP32 MCU</span> <span class="text-slate-600 text-[10px]">HARDWARE</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>ESP-NOW LINK</span> <span class="text-slate-600 text-[10px]">P2P WIRE</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>FREERTOS</span> <span class="text-slate-600 text-[10px]">TASKING</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>PYTORCH</span> <span class="text-slate-600 text-[10px]">DL / LSTM</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>STABLE-BS3</span> <span class="text-slate-600 text-[10px]">DQN (RL)</span>
            </div>
            <div class="flex justify-between p-3 text-slate-400 hover:bg-slate-900/40 hover:text-white transition">
              <span>ONNX RUNTIME</span> <span class="text-slate-600 text-[10px]">COMPILER</span>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
</Layout>