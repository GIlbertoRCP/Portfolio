---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-3xl mx-auto px-6 py-16 space-y-16">
    
    <!-- Profile Summary -->
    <section class="space-y-6">
      <h1 class="text-4xl font-display font-extrabold text-white">About Me</h1>
      <p class="text-lg text-slate-400 leading-relaxed font-sans">
        Hi! I'm Gilberto Romero-Cano, a Computer Science student at the <strong>University of Colorado Denver</strong>.
      </p>
      <p class="text-slate-300 leading-relaxed">
        I've always been drawn to the intersection of hardware and software. I love understanding how electric currents and logic gates translate into high-level programming instructions, and how these systems can be coordinated using distributed, modern cloud architectures.
      </p>
    </section>

    <!-- Education Timeline -->
    <section class="space-y-6">
      <h2 class="text-2xl font-display font-extrabold text-white">Education &amp; Coursework</h2>
      
      <div class="border-l-2 border-slate-900 pl-6 space-y-8">
        
        <div class="relative">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-blue-500 border-4 border-slate-950"></div>
          <span class="text-xs text-slate-500 font-bold font-mono">EXPECTED GRADUATION 2027</span>
          <h4 class="text-base font-semibold text-white mt-1">B.S. in Computer Science</h4>
          <p class="text-xs text-slate-400 font-medium">University of Colorado Denver</p>
          <p class="text-xs text-slate-400 mt-2 font-mono">
            Focus: Software Engineering, Distributed Systems, ML Inference, and Embedded IoT Systems.
          </p>
        </div>

        <div class="relative">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-indigo-500 border-4 border-slate-950"></div>
          <span class="text-xs text-slate-500 font-bold font-mono">KEY COMPLETED COURSEWORK</span>
          <h4 class="text-base font-semibold text-white mt-1">CSCI 4930: Embedded Systems</h4>
          <p class="text-xs text-slate-400 mt-2 leading-relaxed">
            Hands-on work developing firmware for node arrays using microcontrollers. Built physical sensors, tremor-detection accelerometer loops, and P2P communication systems.
          </p>
        </div>

      </div>
    </section>

    <!-- Technical Focus Areas -->
    <section class="space-y-6">
      <h2 class="text-2xl font-display font-extrabold text-white">Technical Core Philosophy</h2>
      <p class="text-slate-300 leading-relaxed">
        I believe that modern computer science demands versatility. I don't confine myself to one layer of the technology stack:
      </p>
      
      <div class="grid sm:grid-cols-2 gap-6 mt-4">
        <div class="bg-slate-950/40 border border-slate-900 rounded-xl p-5 space-y-2">
          <h4 class="text-sm font-bold text-white flex items-center gap-2">
            <span class="text-blue-400">🤖</span> IoT &amp; Hardware Integration
          </h4>
          <p class="text-xs text-slate-400 leading-relaxed">
            Comfortable flashing C++ microcontrollers, wiring analog peripherals, and routing telemetry queues across wireless peer-to-peer radio meshes (like ESP-NOW).
          </p>
        </div>

        <div class="bg-slate-950/40 border border-slate-900 rounded-xl p-5 space-y-2">
          <h4 class="text-sm font-bold text-white flex items-center gap-2">
            <span class="text-purple-400">📈</span> Data Pipelines &amp; ML
          </h4>
          <p class="text-xs text-slate-400 leading-relaxed">
            Experienced with event-streaming brokers like Apache Kafka, deep learning libraries in PyTorch, and optimization techniques (dynamic ONNX compilation and INT8 quantization).
          </p>
        </div>
      </div>
    </section>

    <!-- Call to action -->
    <section class="pt-6 border-t border-slate-900 flex justify-between items-center">
      <span class="text-xs text-slate-500 font-mono">Denver, Colorado</span>
      <a href="https://github.com/GIlbertoRCP" target="_blank" rel="noopener noreferrer" class="text-xs text-blue-400 hover:underline font-semibold flex items-center gap-1">
        Inspect GitHub Repositories &rarr;
      </a>
    </section>

  </main>
</Layout>
