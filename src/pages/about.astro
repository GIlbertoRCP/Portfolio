---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-3xl mx-auto px-6 py-16 space-y-16">
    
    <!-- Profile Summary -->
    <section class="space-y-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-900 pb-6">
        <div>
          <h1 class="text-4xl font-display font-extrabold text-white">Gilberto Romero-Cano</h1>
          <p class="text-lg text-blue-400 font-sans mt-1">Computer Science Student &amp; Software Developer</p>
        </div>
        <div class="bg-slate-900/40 border border-slate-900 rounded-xl p-4 text-xs font-mono text-slate-300 space-y-1.5 md:min-w-[280px] shadow-md shadow-black/20">
          <p>Denver, CO</p>
          <p><a href="tel:7206936526" class="hover:text-blue-400 transition">(720) 693-6526</a></p>
          <p><a href="mailto:gilbertorcp712@gmail.com" class="hover:text-blue-400 transition">gilbertorcp712@gmail.com</a></p>
          <p><a href="https://linkedin.com/in/gromerocano/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition">linkedin.com/in/gromerocano/</a></p>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-xl font-display font-extrabold text-white">Career Summary</h2>
        <p class="text-slate-300 leading-relaxed text-[15px]">
          Computer Science student with a strong foundation in software architecture, backend development, and machine learning. Experienced in building end-to-end applications, from data modeling and predictive pipeline implementation in Python to engineering scalable backends using C# and FastAPI. Passionate about solving problems, managing Linux/Docker environments, and translating raw data into functional software solutions.
        </p>
      </div>
    </section>

    <!-- Education Timeline -->
    <section class="space-y-6">
      <h2 class="text-2xl font-display font-extrabold text-white">Education &amp; Coursework</h2>
      
      <div class="border-l-2 border-slate-900 pl-6 space-y-8">
        
        <div class="relative">
          <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-blue-500 border-4 border-slate-950"></div>
          <span class="text-xs text-slate-500 font-bold font-mono">EXPECTED GRADUATION: MAY 2027</span>
          <h4 class="text-base font-semibold text-white mt-1">Bachelor of Science in Computer Science</h4>
          <p class="text-xs text-slate-400 font-medium">University of Colorado Denver</p>
          
          <div class="mt-4">
            <span class="text-[10px] text-slate-500 font-bold uppercase tracking-wider block mb-2">Relevant Coursework</span>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Data Structures &amp; Algorithms</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Machine Learning</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Software Engineering</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Computer Networks</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Operating Systems</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 rounded-lg text-xs text-slate-300 font-medium">Databases</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Technical Focus Areas -->
    <section class="space-y-6">
      <h2 class="text-2xl font-display font-extrabold text-white">Technical Core Philosophy</h2>
      <p class="text-slate-300 leading-relaxed text-[15px]">
        I believe that modern computer science demands versatility. I don't confine myself to one layer of the technology stack:
      </p>
      
      <div class="grid sm:grid-cols-2 gap-6 mt-4">
        <div class="bg-slate-950/40 border border-slate-900 rounded-xl p-5 space-y-2">
          <h4 class="text-sm font-bold text-white flex items-center gap-2">
            <span class="text-blue-400 font-semibold font-mono">/</span> IoT &amp; Hardware Integration
          </h4>
          <p class="text-xs text-slate-400 leading-relaxed">
            Comfortable flashing C++ microcontrollers, wiring analog peripherals, and routing telemetry queues across wireless peer-to-peer radio meshes (like ESP-NOW).
          </p>
        </div>

        <div class="bg-slate-950/40 border border-slate-900 rounded-xl p-5 space-y-2">
          <h4 class="text-sm font-bold text-white flex items-center gap-2">
            <span class="text-purple-400 font-semibold font-mono">/</span> Data Pipelines &amp; ML
          </h4>
          <p class="text-xs text-slate-400 leading-relaxed">
            Experienced with event-streaming brokers like Apache Kafka, deep learning libraries in PyTorch, and optimization techniques (dynamic ONNX compilation and INT8 quantization).
          </p>
        </div>
      </div>
    </section>

    <!-- Call to action -->
    <section class="pt-6 border-t border-slate-900 flex justify-between items-center">
      <span class="text-xs text-slate-500 font-mono">Denver, Colorado</span>
      <a href="https://github.com/GIlbertoRCP" target="_blank" rel="noopener noreferrer" class="text-xs text-blue-400 hover:underline font-semibold flex items-center gap-1">
        Inspect GitHub Repositories &rarr;
      </a>
    </section>

  </main>
</Layout>
